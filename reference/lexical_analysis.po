msgstr ""
"Especificadores de formato de nĂ­vel superior podem incluir campos de "
"substituiĂ§ĂŁo aninhados::"

#: ../../reference/lexical_analysis.rst:1165
msgid ""
">>> field_size = 20\n"
">>> precision = 7\n"
">>> f'{number:{field_size}.{precision}f}'\n"
"'          14.3000000'"
msgstr ""
">>> tamanho_campo = 20\n"
">>> precisao = 7\n"
">>> f'{numero:{tamanho_campo}.{precisao}f}'\n"
"'          14.3000000'"

#: ../../reference/lexical_analysis.rst:1170
msgid ""
"These nested fields may include their own conversion fields and :ref:`format "
"specifiers <formatspec>`::"
msgstr ""
"Esses campos aninhados podem incluir seus prĂłprios especificadores de "
"conversĂŁo campo e :ref:`especificador de formato <formatspec>` ::"

#: ../../reference/lexical_analysis.rst:1173
msgid ""
">>> number = 3\n"
">>> f'{number:{field_size}}'\n"
"'                   3'\n"
">>> f'{number:{field_size:05}}'\n"
"'00000000000000000003'"
msgstr ""
">>> numero = 3\n"
">>> f'{numero:{tamanho_campo}}'\n"
"'                   3'\n"
">>> f'{numero:{tamanho_campo:05}}'\n"
"'00000000000000000003'"

#: ../../reference/lexical_analysis.rst:1179
msgid ""
"However, these nested fields may not include more deeply nested replacement "
"fields."
msgstr ""
"No entanto, esses campos aninhados nĂŁo podem incluir campos de substituiĂ§ĂŁo "
"mais profundamente aninhados."

#: ../../reference/lexical_analysis.rst:1182
msgid ""
"Formatted string literals cannot be used as :term:`docstrings <docstring>`, "
"even if they do not include expressions::"
msgstr ""
"Literais de strings formatadas nĂŁo podem ser usadas como :term:`docstrings "
"<docstring>` , mesmo que nĂŁo incluam expressĂľes::"

#: ../../reference/lexical_analysis.rst:1185
msgid ""
