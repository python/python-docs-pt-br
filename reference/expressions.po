msgstr "``[expressĂ”es...]``, ``{chave: valor...}``, ``{expressĂ”es...}``"

#: ../../reference/expressions.rst:2148
msgid ""
"Binding or parenthesized expression, list display, dictionary display, set "
"display"
msgstr ""
"ExpressĂŁo entre parĂȘnteses ou de ligaĂ§ĂŁo, sintaxe de criaĂ§ĂŁo de lista, "
"sintaxe de criaĂ§ĂŁo de dicionĂĄrio, sintaxe de criaĂ§ĂŁo de conjunto"

