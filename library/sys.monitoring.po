"Uma exceĂ§ĂŁo levantada por qualquer chamĂˇvel, exceto funĂ§Ăµes Python (o evento "
"ocorre apĂłs a saĂ­da)."

#: ../../library/sys.monitoring.rst:104
msgid ""
"Return from any callable, except for Python functions (event occurs after "
"the return)."
msgstr ""
"Retorno de qualquer chamĂˇvel, exceto por funĂ§Ăµes Python (o evento ocorre "
"apĂłs o retorno)."

#: ../../library/sys.monitoring.rst:108
msgid "An exception is handled."
msgstr "Uma exceĂ§ĂŁo Ă© tratada."

#: ../../library/sys.monitoring.rst:112
