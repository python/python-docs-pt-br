"\n"
"with localcontext() as ctx:\n"
"    ctx.prec = 42   # Efetua um cĂĄlculo de alta precisĂŁo\n"
"    s = calculate_something()\n"
"s = +s  # Arredonda o resultado final de volta para a precisĂŁo padrĂŁo"

#: ../../library/decimal.rst:1041
