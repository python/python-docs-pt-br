">>> x + 2\n"
"Traceback (most recent call last):\n"
"  File \"<stdin>\", line 1, in <module>\n"
"  decimal.Inexact: [<class 'decimal.Inexact'>]"
msgstr ""
">>> import sys\n"
">>>\n"
">>> # NĂșmero mĂĄximo de dĂ­gitos para um Ășnico operando usando 500 MB\n"
">>> # em palavras de 8 bytes com 19 dĂ­gitos por palavra (4 bytes e 9 "
"dĂ­gitos\n"
">>> # para a construĂ§ĂŁo de 32 bits):\n"
">>> maxdigits = 19 * ((500 * 1024**2) // 8)\n"
">>>\n"
">>> # Confere que isso funciona:\n"
">>> c = Context(prec=maxdigits, Emax=MAX_EMAX, Emin=MIN_EMIN)\n"
">>> c.traps[Inexact] = True\n"
">>> setcontext(c)\n"
">>>\n"
">>> # Preenche a precisĂŁo disponĂ­vel com noves:\n"
">>> x = Decimal(0).logical_invert() * 9\n"
