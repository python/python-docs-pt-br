"\n"
"    # To prevent keeping references to finished tasks forever,\n"
"    # make each task remove its own reference from the set after\n"
"    # completion:\n"
"    task.add_done_callback(background_tasks.discard)"
msgstr ""
"background_tasks = set()for i in range(10):    task = asyncio."
"create_task(some_coro(param=i))    # Adiciona tarefa ao conjunto. Isto cria "
"uma referûˆncia forte.    background_tasks.add(task)    # Para evitar manter "
"referûˆncias a tarefas concluûÙdas para sempre,    # fazer com que cada tarefa "
"remova a sua prû°pria referûˆncia do conjunto apû°s    # a conclusûÈo:    task."
"add_done_callback(background_tasks.discard)"

