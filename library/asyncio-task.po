#: ../../library/asyncio-task.rst:479
msgid "Running Tasks Concurrently"
msgstr "Executando tarefas concorrentemente"

#: ../../library/asyncio-task.rst:483
msgid ""
"Run :ref:`awaitable objects <asyncio-awaitables>` in the *aws* sequence "
