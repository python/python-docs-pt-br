#: ../../library/os.rst:5466
msgid "Scheduling policy for extremely low priority background tasks."
msgstr ""
"PolĂ­tica de agendamento para tarefas em segundo plano de prioridade "
"extremamente baixa."

#: ../../library/os.rst:5470
msgid "Alias for :data:`SCHED_OTHER`."
