#: ../../library/plistlib.rst:209
msgid ""
"import plistlib\n"
"\n"
"plist = b\"\"\"<plist version=\"1.0\">\n"
"<dict>\n"
"    <key>foo</key>\n"
"    <string>bar</string>\n"
"</dict>\n"
"</plist>\"\"\"\n"
"pl = plistlib.loads(plist)\n"
"print(pl[\"foo\"])"
msgstr ""
