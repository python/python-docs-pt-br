msgstr ""

#: ../../c-api/type.rst:906
msgid "If positive, corresponds to :c:macro:`Py_tp_basicsize`."
msgstr ""

#: ../../c-api/type.rst:908
msgid ""
"If negative, corresponds to :c:macro:`Py_tp_extra_basicsize` set to the "
"absolute value."
